# 1. Ignore everything by default
*

# 2. Allow directory structures (non-recursive allow of the directory itself)
!/.cargo/
!/bench/
!/docs/
!/figures/
!/scripts/
!/src/
!/test_data/
!/tests/

# 3. Allow specific root files
!/.gitignore
!/Cargo.lock
!/Cargo.toml
!/README.md
!/analyze_missed_patterns.py
!/find_missed_loci.py
!/analyze_novel.py

# 4. Recursively allow content in these directories
!/.cargo/**
!/bench/**
!/docs/**
!/figures/**
!/scripts/**
!/src/**
!/tests/**

# 5. Specific re-ignores for common junk (must come AFTER allows)
/target/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.rs.bk
.DS_Store
.claude/

# 6. Specific re-ignores for large data files and artifacts
*.bam
*.bam.bai
*.gtf
*.gff
*.fasta
*.fasta.fai
*.fa
*.fa.fai
/archive/
/chr19_stringtie_graphs/
/chr19_stringtie_supported_gfas/
/stringtie_debug/
/test_adaptive*/
/test_auto_recovery/
/test_bundle_graph/
/test_clean/
/test_compat*/
/test_final*/
/test_flow*/
/test_group_only/
/test_integrated/
/test_nofilter/
/test_revert/
/test_sensitive/
/gene_family_detector/

# 7. Test data handling (Keep synthetic family, ignore large chr1 subsets)
/test_data/*
!/test_data/synthetic_family/
!/test_data/synthetic_family/**
*.log
